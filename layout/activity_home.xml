<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".homeActivity">



    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:itemIconTint="#312470"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0"
        app:menu="@menu/menu" />


    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">

        <TextView
            android:id="@+id/textView3"
            android:layout_width="260dp"
            android:layout_height="27dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="50dp"
            android:layout_marginEnd="337dp"
            android:layout_marginRight="337dp"
            android:text="@string/textView3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/editTextText7"
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="130dp"
            android:layout_marginEnd="337dp"
            android:layout_marginRight="337dp"
            android:ems="28"
            android:inputType="text"
            android:text="@string/editTextText7" />

        <TextView
            android:id="@+id/textView9"
            android:layout_width="263dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="95dp"
            android:layout_marginEnd="337dp"
            android:layout_marginRight="337dp"
            android:text="@string/textView9" />

        <TextView
            android:id="@+id/textView10"
            android:layout_width="97dp"
            android:layout_height="26dp"
            android:layout_marginStart="86dp"
            android:layout_marginTop="190dp"
            android:layout_marginEnd="337dp"
            android:layout_marginRight="337dp"

            android:text="@string/textView10" />

        <TextView
            android:id="@+id/textView11"
            android:layout_width="97dp"
            android:layout_height="26dp"
            android:layout_marginStart="226dp"
            android:layout_marginTop="193dp"
            android:layout_marginEnd="337dp"
            android:layout_marginRight="337dp"
            android:includeFontPadding="false"
            android:text="@string/textview11" />

        <TextView
            android:id="@+id/textView12"
            android:layout_width="79dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="235dp"
            android:layout_marginEnd="337dp"
            android:layout_marginRight="337dp"
            android:fontFamily="monospace"
            android:text="@string/textview12" />

        <TextView
            android:id="@+id/textView13"
            android:layout_width="79dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="295dp"
            android:layout_marginEnd="337dp"
            android:layout_marginRight="337dp"
            android:fontFamily="monospace"
            android:text="@string/textview13" />

        <EditText
            android:id="@+id/editTextText8"
            android:layout_width="257dp"
            android:layout_height="57dp"
            android:layout_marginStart="140dp"
            android:layout_marginTop="215dp"
            android:layout_marginEnd="337dp"
            android:layout_marginRight="337dp"
            android:ems="10"
            android:text="Enter Your Destination" />

        <EditText
            android:id="@+id/editTextText9"
            android:layout_width="257dp"
            android:layout_height="57dp"
            android:layout_marginStart="140dp"
            android:layout_marginTop="270dp"
            android:layout_marginEnd="337dp"
            android:layout_marginRight="337dp"
            android:ems="10"
            android:inputType="text"
            android:text="@string/editTextText9" />

        <ImageView
            android:id="@+id/imageView4"
            android:layout_width="227dp"
            android:layout_height="217dp"
            android:layout_marginStart="90dp"
            android:layout_marginTop="350dp"
            android:layout_marginEnd="0dp"
            android:layout_marginRight="100dp"
            app:srcCompat="@drawable/image" />

        <SearchView
            android:layout_width="58dp"
            android:layout_height="28dp"
            android:layout_marginStart="325dp"
            android:layout_marginTop="137dp"
            android:layout_marginEnd="337dp"
            android:layout_marginRight="337dp" />

        <Button
            android:id="@+id/Button6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="145dp"
            android:layout_marginTop="590dp"
            android:layout_marginEnd="0dp"
            android:layout_marginRight="155dp"
            android:shadowColor="@color/blue"
            android:text="@string/Button6"
            android:textColorHighlight="@color/blue"
            android:textColorHint="@color/blue"
            android:textColorLink="@color/blue"
            app:rippleColor="@color/blue"
            app:strokeColor="@color/blue" />


    </FrameLayout>






</androidx.constraintlayout.widget.ConstraintLayout>